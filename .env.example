# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/studymate
# For production, use MongoDB Atlas connection string:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/studymate

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# GLM API Configuration (Chinese LLM - Free/Cheap alternative)
GLM_API_KEY=your_glm_api_key_here
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_VISION_MODEL=glm-4v
GLM_TEXT_MODEL=glm-4

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend Configuration
FRONTEND_URL=http://localhost:5173

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg

# Mental Health Configuration
STRESS_TRACKING_ENABLED=true
RELAXATION_CONTENT_ENABLED=true